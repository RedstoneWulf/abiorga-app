// AbiOrga - Datenbank Schema
// Dieses Schema definiert alle Datenmodelle für die App

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// BENUTZER & ROLLEN
// ============================================================

enum Role {
  ADMIN
  COMMITTEE
  TEAM_LEADER
  MEMBER
}

enum TaskType {
  ONE_TIME
  RECURRING
}

enum TaskStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  VERIFIED
}

enum AssignmentMode {
  AUTO
  MANUAL
}

enum RecurrenceInterval {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum EventType {
  EVENT       // Allgemeines Event (z.B. Abi-Ball Besichtigung)
  EXAM        // Klausur
  DEADLINE    // Wichtiger Termin/Frist
  MEETING     // Treffen
}

enum PollStatus {
  ACTIVE      // Abstimmung läuft
  CLOSED      // Abstimmung beendet
}

enum TeamType {
  COMMITTEE   // Komitee - fast wie Admin-Rechte
  FINANCE     // Finanz-Team - Genehmigungsrechte
  CUSTOM      // Normales Team
}

enum NotificationPriority {
  NORMAL
  HIGH      // Immer zugestellt, kann nicht abgestellt werden
}

enum NotificationType {
  GLOBAL        // Globale Nachricht von Admin/Komitee
  STORY         // Neuer Story-Post
  CHAT          // Neue Chat-Nachricht
  EVENT         // Neues Event/Klausur
  TASK          // Neue Aufgabe zugewiesen
  POLL          // Neue Abstimmung
  TRANSACTION   // Transaktion genehmigt/abgelehnt
}

enum EventVisibility {
  ALL          // Alle sehen es
  TEAM_ONLY    // Nur bestimmte Teams
}

enum ResultVisibility {
  AFTER_VOTE    // Ergebnisse sichtbar nachdem man abgestimmt hat
  BEFORE_VOTE   // Ergebnisse immer sichtbar (auch vor der Abstimmung)
  AFTER_CLOSE   // Ergebnisse erst nach Beendigung sichtbar
}

enum JoinMode {
  OPEN        // Jeder kann beitreten
  REQUEST     // Anfrage muss bestätigt werden
  INVITE_ONLY // Nur per Einladung
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  password       String
  role           Role     @default(MEMBER)
  avatar         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Beziehungen
  teamMemberships   TeamMember[]
  createdTasks      Task[]             @relation("TaskCreator")
  assignments       TaskAssignment[]   @relation("TaskAssignments")
  taskRatings       TaskRating[]       @relation("TaskRatings")
  transactions      Transaction[]      @relation("CreatedBy")
  reviewedTx        Transaction[]      @relation("ReviewedBy")
  notifications     Notification[]     @relation("CreatedBy")
  pushSubscriptions PushSubscription[]
  stories           Story[]
  createdEvents Event[]  @relation("EventCreator")
  createdPolls  Poll[]   @relation("PollCreator")
  votes         Vote[]   @relation("PollVotes")
  chatMessages ChatMessage[] @relation("ChatMessages")
  storyReactions StoryReaction[] @relation("StoryReactions")
  storyComments  StoryComment[]  @relation("StoryComments")
  notificationReads NotificationRead[]       @relation("NotificationReads")
  notificationPrefs NotificationPreference?  @relation("NotificationPrefs")
  eventAttendances EventAttendee[] @relation("EventAttendees")
  teamFollows      TeamFollow[]       @relation("TeamFollows")
  teamJoinRequests TeamJoinRequest[]  @relation("TeamJoinRequests")

  @@map("users")
}

// ============================================================
// Events
// ============================================================
model Event {
  id          String    @id @default(cuid())
  title       String
  description String?
  type        EventType
  category    String?       // z.B. "Treffen", "Fest", "Aufführung" oder eigener Text
  startDate   DateTime
  endDate     DateTime?
  location    String?
  allDay      Boolean   @default(false)

  // Preis
  isFree      Boolean   @default(true)
  price       Float?    // null wenn kostenlos

  // Anmeldung
  registrationRequired Boolean @default(false)
  maxAttendees         Int?    // null = unbegrenzt

  // Sichtbarkeit
  visibility  EventVisibility @default(ALL)

  // Kontakt
  contactName  String?
  contactInfo  String?   // E-Mail oder Telefon

  createdById String
  createdBy   User @relation("EventCreator", fields: [createdById], references: [id])

  teamId String?
  team   Team?  @relation(fields: [teamId], references: [id])

  attendees EventAttendee[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startDate])
  @@index([type])
}

model EventAttendee {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation("EventAttendees", fields: [userId], references: [id])
  
  registeredAt DateTime @default(now())

  @@unique([eventId, userId])
  @@index([eventId])
  @@map("event_attendees")
}

// ============================================================
// Abstimmungen
// ============================================================

model Poll {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      PollStatus @default(ACTIVE)
  allowMultiple Boolean  @default(false)  // Mehrfachauswahl?
  anonymous     Boolean  @default(false)  // Anonyme Abstimmung?
  resultVisibility ResultVisibility @default(AFTER_VOTE)
  closedAt         DateTime?
  endsAt      DateTime?  // Optionales Enddatum

  createdById String
  createdBy   User @relation("PollCreator", fields: [createdById], references: [id])

  options PollOption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PollOption {
  id     String @id @default(cuid())
  text   String
  pollId String
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)

  votes Vote[]

  @@index([pollId])
}

model Vote {
  id       String @id @default(cuid())
  optionId String
  option   PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  voterId String
  voter   User   @relation("PollVotes", fields: [voterId], references: [id])

  createdAt DateTime @default(now())

  @@unique([optionId, voterId])  // Pro Option nur eine Stimme
  @@index([voterId])
}

// ============================================================
// AUFGABEN & BEWERTUNG
// ============================================================

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        TaskType
  status      TaskStatus @default(OPEN)

  // Zuweisung
  assignmentMode AssignmentMode @default(MANUAL)
  isTeamTask     Boolean        @default(false)
  maxAssignees   Int            @default(1)

  // Wiederkehrende Aufgaben
  recurrenceInterval RecurrenceInterval?
  nextDueDate        DateTime?

  // Einmalige Aufgaben
  dueDate    DateTime?

  // Priorität (1 = niedrig, 5 = hoch)
  priority   Int @default(3)

  // Beziehungen
  createdById String
  createdBy   User @relation("TaskCreator", fields: [createdById], references: [id])

  teamId String?
  team   Team?  @relation(fields: [teamId], references: [id])

  assignments TaskAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([nextDueDate])
}

model TaskAssignment {
  id     String @id @default(cuid())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("TaskAssignments", fields: [userId], references: [id])

  assignedAt  DateTime   @default(now())
  dueDate     DateTime?
  completedAt DateTime?

  status TaskStatus @default(ASSIGNED)

  ratings TaskRating[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([taskId, userId, assignedAt])
  @@index([userId])
  @@index([taskId])
}

model TaskRating {
  id String @id @default(cuid())

  assignmentId String
  assignment   TaskAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  raterId String
  rater   User   @relation("TaskRatings", fields: [raterId], references: [id])

  score   Int
  comment String?

  createdAt DateTime @default(now())

  @@unique([assignmentId, raterId])
  @@index([assignmentId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

// ============================================================
// TEAMS
// ============================================================

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  type TeamType @default(CUSTOM)
  color       String   @default("#4472C4")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  joinMode    JoinMode @default(OPEN)
  icon        String?   // Emoji oder Buchstabe als Avatar
  createdById String?
  

  members       TeamMember[]
  tasks         Task[]
  notifications Notification[]
  stories       Story[]
  chatMessages  ChatMessage[]
  events Event[]
  followers   TeamFollow[]
  joinRequests TeamJoinRequest[]

  @@map("teams")
}

model TeamMember {
  id       String  @id @default(cuid())
  userId   String
  teamId   String
  isLeader Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@map("team_members")
}

model TeamFollow {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("TeamFollows", fields: [userId], references: [id])
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, teamId])
  @@map("team_follows")
}

model TeamJoinRequest {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("TeamJoinRequests", fields: [userId], references: [id])
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  status String @default("PENDING") // PENDING, APPROVED, REJECTED

  createdAt DateTime @default(now())

  @@unique([userId, teamId])
  @@map("team_join_requests")
}

// ============================================================
// FINANZEN
// ============================================================

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  PENDING
  APPROVED
  REJECTED
}

model Transaction {
  id           String            @id @default(cuid())
  amount       Float
  type         TransactionType
  status       TransactionStatus @default(PENDING)
  reason       String
  category     String?
  rejectReason String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  transactionDate   DateTime?   // Alternatives Datum (geplante Einzahlung oder Kaufdatum)
  receiptUrl        String?     // Beleg-Foto als Base64
  receiptExpiresAt  DateTime?   // 48h nach Genehmigung/Ablehnung → dann wird receiptUrl gelöscht

  createdById  String
  createdBy    User @relation("CreatedBy", fields: [createdById], references: [id])

  reviewedById String?
  reviewedBy   User?  @relation("ReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?

  @@map("transactions")
}

// ============================================================
// BENACHRICHTIGUNGEN
// ============================================================

enum NotificationScope {
  GLOBAL
  TEAM
}

model Notification {
  id        String               @id @default(cuid())
  title     String
  message   String
  scope     NotificationScope    @default(GLOBAL)
  type      NotificationType     @default(GLOBAL)
  priority  NotificationPriority @default(NORMAL)
  pinned    Boolean              @default(false)
  createdAt DateTime             @default(now())

  createdById String
  createdBy   User @relation("CreatedBy", fields: [createdById], references: [id])

  teamId String?
  team   Team?  @relation(fields: [teamId], references: [id])

  // Welche User haben sie gelesen?
  readBy NotificationRead[]

  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationRead {
  id             String       @id @default(cuid())
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("NotificationReads", fields: [userId], references: [id])
  readAt         DateTime     @default(now())

  @@unique([notificationId, userId])
  @@index([userId])
  @@map("notification_reads")
}

model NotificationPreference {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation("NotificationPrefs", fields: [userId], references: [id])

  // Welche Benachrichtigungen will der User?
  stories      Boolean @default(true)
  chat         Boolean @default(true)
  events       Boolean @default(true)
  tasks        Boolean @default(true)
  polls        Boolean @default(true)
  transactions Boolean @default(true)
  global       Boolean @default(true)
  // HIGH priority kann NICHT abgestellt werden

  @@map("notification_preferences")
}

// ============================================================
// STORIES
// ============================================================

model Story {
  id        String   @id @default(cuid())
  mediaUrl  String?
  text      String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  createdById String
  createdBy   User @relation(fields: [createdById], references: [id])

  teamId String?
  team   Team?  @relation(fields: [teamId], references: [id])

  reactions StoryReaction[]
  comments StoryComment[]

  @@map("stories")
}

model StoryReaction {
  id      String @id @default(cuid())
  storyId String
  userId  String
  emoji   String

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)
  user User @relation("StoryReactions", fields: [userId], references: [id])

  @@unique([storyId, userId])
  @@map("story_reactions")
}

model StoryComment {
  id        String   @id @default(cuid())
  content   String
  storyId   String
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("StoryComments", fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([storyId])
  @@map("story_comments")
}

// ============================================================
// TEAM-CHAT
// ============================================================

model ChatMessage {
  id        String   @id @default(cuid())
  content   String
  teamId    String
  userId    String
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation("ChatMessages", fields: [userId], references: [id])

  @@map("chat_messages")
}

model AppSettings {
  id    String @id @default("app-settings")
  financeGoal Float @default(5000)
  updatedAt   DateTime @updatedAt
}
