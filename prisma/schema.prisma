// AbiOrga - Datenbank Schema
// Dieses Schema definiert alle Datenmodelle für die App

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// BENUTZER & ROLLEN
// ============================================================

enum Role {
  ADMIN
  COMMITTEE
  TEAM_LEADER
  MEMBER
}

enum TaskType {
  ONE_TIME
  RECURRING
}

enum TaskStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  VERIFIED
}

enum AssignmentMode {
  AUTO
  MANUAL
}

enum RecurrenceInterval {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  password       String
  role           Role     @default(MEMBER)
  avatar         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Beziehungen
  teamMemberships   TeamMember[]
  createdTasks      Task[]             @relation("TaskCreator")
  assignments       TaskAssignment[]   @relation("TaskAssignments")
  taskRatings       TaskRating[]       @relation("TaskRatings")
  transactions      Transaction[]      @relation("CreatedBy")
  reviewedTx        Transaction[]      @relation("ReviewedBy")
  notifications     Notification[]     @relation("CreatedBy")
  pushSubscriptions PushSubscription[]
  stories           Story[]

  @@map("users")
}

// ============================================================
// AUFGABEN & BEWERTUNG
// ============================================================

model Task {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        TaskType
  status      TaskStatus @default(OPEN)

  // Zuweisung
  assignmentMode AssignmentMode @default(MANUAL)
  isTeamTask     Boolean        @default(false)
  maxAssignees   Int            @default(1)

  // Wiederkehrende Aufgaben
  recurrenceInterval RecurrenceInterval?
  nextDueDate        DateTime?

  // Einmalige Aufgaben
  dueDate    DateTime?

  // Priorität (1 = niedrig, 5 = hoch)
  priority   Int @default(3)

  // Beziehungen
  createdById String
  createdBy   User @relation("TaskCreator", fields: [createdById], references: [id])

  teamId String?
  team   Team?  @relation(fields: [teamId], references: [id])

  assignments TaskAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([type])
  @@index([nextDueDate])
}

model TaskAssignment {
  id     String @id @default(cuid())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("TaskAssignments", fields: [userId], references: [id])

  assignedAt  DateTime   @default(now())
  dueDate     DateTime?
  completedAt DateTime?

  status TaskStatus @default(ASSIGNED)

  ratings TaskRating[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([taskId, userId, assignedAt])
  @@index([userId])
  @@index([taskId])
}

model TaskRating {
  id String @id @default(cuid())

  assignmentId String
  assignment   TaskAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  raterId String
  rater   User   @relation("TaskRatings", fields: [raterId], references: [id])

  score   Int
  comment String?

  createdAt DateTime @default(now())

  @@unique([assignmentId, raterId])
  @@index([assignmentId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

// ============================================================
// TEAMS
// ============================================================

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  color       String   @default("#4472C4")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members       TeamMember[]
  tasks         Task[]
  notifications Notification[]
  stories       Story[]
  chatMessages  ChatMessage[]

  @@map("teams")
}

model TeamMember {
  id       String  @id @default(cuid())
  userId   String
  teamId   String
  isLeader Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@map("team_members")
}

// ============================================================
// FINANZEN
// ============================================================

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  PENDING
  APPROVED
  REJECTED
}

model Transaction {
  id           String            @id @default(cuid())
  amount       Float
  type         TransactionType
  status       TransactionStatus @default(PENDING)
  reason       String
  category     String?
  rejectReason String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  createdById  String
  createdBy    User @relation("CreatedBy", fields: [createdById], references: [id])

  reviewedById String?
  reviewedBy   User?  @relation("ReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?

  @@map("transactions")
}

// ============================================================
// BENACHRICHTIGUNGEN
// ============================================================

enum NotificationScope {
  GLOBAL
  TEAM
}

model Notification {
  id        String            @id @default(cuid())
  title     String
  message   String
  scope     NotificationScope @default(GLOBAL)
  pinned    Boolean           @default(false)
  createdAt DateTime          @default(now())

  createdById String
  createdBy   User @relation("CreatedBy", fields: [createdById], references: [id])

  teamId String?
  team   Team?  @relation(fields: [teamId], references: [id])

  @@map("notifications")
}

// ============================================================
// STORIES
// ============================================================

model Story {
  id        String   @id @default(cuid())
  mediaUrl  String?
  text      String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  createdById String
  createdBy   User @relation(fields: [createdById], references: [id])

  teamId String?
  team   Team?  @relation(fields: [teamId], references: [id])

  reactions StoryReaction[]

  @@map("stories")
}

model StoryReaction {
  id      String @id @default(cuid())
  storyId String
  userId  String
  emoji   String

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId])
  @@map("story_reactions")
}

// ============================================================
// TEAM-CHAT
// ============================================================

model ChatMessage {
  id        String   @id @default(cuid())
  content   String
  teamId    String
  userId    String
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}
