// AbiOrga - Datenbank Schema
// Dieses Schema definiert alle Datenmodelle für die App

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// BENUTZER & ROLLEN
// ============================================================

enum Role {
  ADMIN
  TEAM_LEADER
  MEMBER
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  password       String   // Gehashtes Passwort
  role           Role     @default(MEMBER)
  avatar         String?  // Profilbild-URL (optional)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Beziehungen
  teamMemberships TeamMember[]
  assignedTasks   Task[]             @relation("AssignedTo")
  createdTasks    Task[]             @relation("CreatedBy")
  taskRatings     TaskRating[]
  transactions    Transaction[]      @relation("CreatedBy")
  reviewedTx      Transaction[]      @relation("ReviewedBy")
  notifications   Notification[]     @relation("CreatedBy")
  pushSubscriptions PushSubscription[]
  stories         Story[]

  @@map("users")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String   // Verschlüsselungs-Keys für Web Push
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

// ============================================================
// TEAMS
// ============================================================

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  color       String   @default("#4472C4") // Farbe für UI
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Beziehungen
  members       TeamMember[]
  tasks         Task[]
  notifications Notification[]
  stories       Story[]
  chatMessages  ChatMessage[]

  @@map("teams")
}

model TeamMember {
  id       String  @id @default(cuid())
  userId   String
  teamId   String
  isLeader Boolean @default(false) // Teamleiter?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId]) // Jeder User nur einmal pro Team
  @@map("team_members")
}

// ============================================================
// AUFGABEN & BEWERTUNG
// ============================================================

enum TaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  RATED
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(OPEN)
  deadline    DateTime?
  isRecurring Boolean    @default(false) // Wiederkehrende Aufgabe?
  recurringDays Int?     // Alle X Tage rotieren
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Zuweisung
  assignedToId String?
  createdById  String
  teamId       String?

  assignedTo User?  @relation("AssignedTo", fields: [assignedToId], references: [id])
  createdBy  User   @relation("CreatedBy", fields: [createdById], references: [id])
  team       Team?  @relation(fields: [teamId], references: [id])

  // Bewertungen
  ratings TaskRating[]

  // Rotations-Historie
  rotationHistory TaskRotation[]

  @@map("tasks")
}

model TaskRating {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  stars     Int      // 1-5 Sterne
  thumbsUp  Boolean  // Daumen hoch oder runter
  comment   String?  // Optionaler Kommentar
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId]) // Jeder User kann nur einmal pro Aufgabe bewerten
  @@map("task_ratings")
}

model TaskRotation {
  id         String   @id @default(cuid())
  taskId     String
  userId     String   // Wer war dran?
  startDate  DateTime
  endDate    DateTime?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_rotations")
}

// ============================================================
// FINANZEN
// ============================================================

enum TransactionType {
  INCOME      // Einzahlung
  EXPENSE     // Auszahlung
}

enum TransactionStatus {
  PENDING     // Vormerkung (nur Admins sichtbar)
  APPROVED    // Bestätigt (öffentlich)
  REJECTED    // Abgelehnt
}

model Transaction {
  id           String            @id @default(cuid())
  amount       Float             // Betrag in Euro
  type         TransactionType
  status       TransactionStatus @default(PENDING)
  reason       String            // Grund der Transaktion
  category     String?           // z.B. "Deko", "Catering", "Sonstiges"
  rejectReason String?           // Grund bei Ablehnung
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  // Wer hat es eingetragen?
  createdById  String
  createdBy    User @relation("CreatedBy", fields: [createdById], references: [id])

  // Wer hat es bestätigt/abgelehnt?
  reviewedById String?
  reviewedBy   User?  @relation("ReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?

  @@map("transactions")
}

// ============================================================
// BENACHRICHTIGUNGEN
// ============================================================

enum NotificationScope {
  GLOBAL    // Für die gesamte Stufe
  TEAM      // Nur für ein bestimmtes Team
}

model Notification {
  id        String            @id @default(cuid())
  title     String
  message   String
  scope     NotificationScope @default(GLOBAL)
  pinned    Boolean           @default(false) // Oben angeheftet?
  createdAt DateTime          @default(now())

  // Wer hat sie erstellt?
  createdById String
  createdBy   User @relation("CreatedBy", fields: [createdById], references: [id])

  // Optional: für welches Team?
  teamId String?
  team   Team?  @relation(fields: [teamId], references: [id])

  @@map("notifications")
}

// ============================================================
// STORIES (Phase 4, aber Schema schon vorbereitet)
// ============================================================

model Story {
  id        String   @id @default(cuid())
  mediaUrl  String?  // Bild oder Video URL
  text      String?  // Text-Inhalt
  expiresAt DateTime // Ablaufzeit (48 Stunden nach Erstellung)
  createdAt DateTime @default(now())

  // Erstellt von User (muss Admin oder Teamleiter sein)
  createdById String
  createdBy   User @relation(fields: [createdById], references: [id])

  // Optional: im Namen eines Teams
  teamId String?
  team   Team?  @relation(fields: [teamId], references: [id])

  // Reaktionen
  reactions StoryReaction[]

  @@map("stories")
}

model StoryReaction {
  id      String @id @default(cuid())
  storyId String
  userId  String
  emoji   String // z.B. "🎉", "❤️", "👍"

  story Story @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([storyId, userId]) // Ein Emoji pro User pro Story
  @@map("story_reactions")
}

// ============================================================
// TEAM-CHAT (Phase 4, aber Schema schon vorbereitet)
// ============================================================

model ChatMessage {
  id        String   @id @default(cuid())
  content   String
  teamId    String
  userId    String
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}
